// Responder queries
export async function getRespondersByWard(wardId: number) {
  const db = await getDb();
  if (!db) return [];
  return db
    .select()
    .from(responders)
    .where(and(eq(responders.wardId, wardId), eq(responders.isActive, 1)));
}

export async function getAllResponders() {
  const db = await getDb();
  if (!db) return [];
  return db.select().from(responders).where(eq(responders.isActive, 1));
}

export async function createResponder(data: InsertResponder) {
  const db = await getDb();
  if (!db) throw new Error("Database not available");
  await db.insert(responders).values(data);
}

export async function updateResponder(id: number, data: Partial<InsertResponder>) {
  const db = await getDb();
  if (!db) throw new Error("Database not available");
  await db.update(responders).set(data).where(eq(responders.id, id));
}

export async function deleteResponder(id: number) {
  const db = await getDb();
  if (!db) throw new Error("Database not available");
  await db.update(responders).set({ isActive: 0 }).where(eq(responders.id, id));
}

// Alert queries
export async function createAlert(data: InsertAlert) {
  const db = await getDb();
  if (!db) throw new Error("Database not available");
  await db.insert(alerts).values(data);
}

export async function getAlertHistory(limit: number = 100) {
  const db = await getDb();
  if (!db) return [];
  return db.select().from(alerts).orderBy(desc(alerts.sentAt)).limit(limit);
}

export async function getAlertsByResponder(responderId: number, limit: number = 50) {
  const db = await getDb();
  if (!db) return [];
  return db
    .select()
    .from(alerts)
    .where(eq(alerts.responderId, responderId))
    .orderBy(desc(alerts.sentAt))
    .limit(limit);
}

// Current ward risk queries
export async function getCurrentWardRisks() {
  const db = await getDb();
  if (!db) return [];
  return db.select().from(currentWardRisk);
}

export async function getCurrentWardRisk(wardId: number) {
  const db = await getDb();
  if (!db) return null;
  const result = await db
    .select()
    .from(currentWardRisk)
    .where(eq(currentWardRisk.wardId, wardId))
    .limit(1);
  return result.length > 0 ? result[0] : null;
}

export async function upsertCurrentWardRisk(data: InsertCurrentWardRisk) {
  const db = await getDb();
  if (!db) throw new Error("Database not available");
  await db
    .insert(currentWardRisk)
    .values(data)
    .onDuplicateKeyUpdate({
      set: {
        riskLevel: data.riskLevel,
        rainfall24h: data.rainfall24h,
        lastUpdated: data.lastUpdated,
      },
    });
}
