}

export async function updateFloodIncident(id: number, data: Partial<InsertFloodIncident>) {
  const db = await getDb();
  if (!db) throw new Error("Database not available");
  await db.update(floodIncidents).set(data).where(eq(floodIncidents.id, id));
}

export async function deleteFloodIncident(id: number) {
  const db = await getDb();
  if (!db) throw new Error("Database not available");
  await db.delete(floodIncidents).where(eq(floodIncidents.id, id));
